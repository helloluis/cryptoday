generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id             String   @id @default(uuid())
  title          String
  url            String   @unique
  source         String
  sourceSlug     String
  publishedAt    DateTime
  fetchedAt      DateTime @default(now())
  content        String?
  summary        String?
  category       String   @default("ALL")
  sentimentScore Float?
  sentimentLabel String?
  analyzed       Boolean  @default(false)
  apiKeyId       String?
  searchQuery    String?

  @@index([publishedAt])
  @@index([source])
  @@index([category])
  @@index([analyzed])
  @@index([apiKeyId])
}

model ApiKey {
  id             String         @id @default(uuid())
  key            String         @unique
  name           String
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  customSearches CustomSearch[]
}

model CustomSearch {
  id        String   @id @default(uuid())
  query     String
  provider  String   @default("google") // "google", "gnw", "both"
  active    Boolean  @default(true)
  apiKeyId  String
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id])
  createdAt DateTime @default(now())

  @@index([apiKeyId])
  @@unique([apiKeyId, query])
}

model NewsSummary {
  id             String   @id @default(uuid())
  periodStart    DateTime @unique
  periodEnd      DateTime
  summary        String
  sentimentScore Float
  sentimentLabel String
  articleCount   Int
  createdAt      DateTime @default(now())

  @@index([periodStart])
}

model Source {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  feedUrl  String
  active   Boolean @default(true)
  category String  @default("ALL")
}
